# Rockstar Law Registration MVP
# Copy this file to .env.local and fill values when Supabase is wired.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email notifications (Resend)
RESEND_API_KEY=
EMAIL_FROM="RockStar Law <onboarding@resend.dev>"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# DEV QUICK-LOGIN (Phase A.1) — NEVER uncomment these in a production environment.
# These variables enable a password-bypass endpoint at /api/dev/quick-login
# that lets automated tests sign in instantly. Three gates prevent accidental
# production exposure (NODE_ENV, hostname check, and this var), but the
# safest approach is to only ever set them in .env.local, never committed.
#
# To activate: copy to .env.local and uncomment.
# To seed test accounts: npm run seed:dev-users
# ─────────────────────────────────────────────────────────────────────────────
# ALLOW_DEV_QUICK_LOGIN=true
# NEXT_PUBLIC_ALLOW_DEV_QUICK_LOGIN=true
# QUICK_LOGIN_DEV_PASSWORD=Rockstar2026!Dev#Test
