{
  "header":{
      "title": "Apply for an Employer Identification Number (EIN)",
      "additionalText": [
        "Use this assistance to apply for and obtain an Employee Identification Number (EIN)"
      ]
  },
  "reviewAndSubmitSection": {
    "subHeader":{
      "title": "Review and Submit",
      "additionalText": [
        "All fields marked with an asterisk (<Red>*</Red>) are required."
      ]
    },
    "reviewBeforeSubmittingAlert": {
      "title": "Review your information before submitting.",
      "additionalText": [
          "Please review the information you are about to submit. If any of the information below is incorrect, you will need to start a new application.<br><br>",
          "Click the \"Submit EIN Request\" button at the bottom of the page to receive your EIN."
      ]
    },
    "confirmationLetterInstructions":{
      "title": "How would you like to receive your EIN Confirmation Letter?",
      "additionalText": [
      ]
    },
    "confirmationLetterInputControl": {
        "fieldName": "You have two options for receiving your confirmation letter. Please choose one below",
        "additionalText": [],
        "type" : "RadioInput",
        "choices": [
          {
              "value" : "DIGITAL",
              "text" : "Receive letter digitally in the next step",
              "additionalText": [
                "This option requires Adobe Reader. You will be able to view, print, and save this letter immediately. It will not be mailed to you."
              ]
          },
          {
              "value" : "MAIL",
              "text" : "Receive letter by mail (allow up to 4 weeks for delivery)",
              "additionalText": [
                "The IRS will send the letter to the mailing address you provided."
              ]
          }
        ],
        "inputErrorMessages": [
            {
                "text": "Confirmation Letter: Selection is required.",
                "id": "confirmationLetterInputControl_error1",
                "additionalText": []
            }
        ]
      },
